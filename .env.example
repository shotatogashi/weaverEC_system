# app/orders のみ: Google OAuth トークン保存ディレクトリ（DocumentRoot 外。chmod 700 推奨）
# 例: TOKEN_STORAGE_PATH=/home/weaver-ec/storage/secure/tokens
TOKEN_STORAGE_PATH=

# app/orders 用環境変数（セキュリティ強化版）
# このファイルを .env にコピーし、値を設定してください
# cp .env.example .env

# 楽天API シークレットキー（必須）
RAKUTEN_SECRET_KEY=

# 楽天API ライセンスキー（いずれか必須。公開ディレクトリに置かないこと）
# RAKUTEN_LICENSE_KEY=           # 値を直接書く場合
# RAKUTEN_LICENSE_KEY_PATH=      # DocumentRoot 外のファイルパス（本番例: /home/weaver-ec/storage/secure/keys/rakuten_license_key.txt）
RAKUTEN_LICENSE_KEY_PATH=

# ライセンス更新フォームの認証（update_license.php のみ）
ADMIN_USERNAME=
ADMIN_PASSWORD=

# 一般ページの認証（index.php, order_book.php, sample_order_book.php）
USER_USERNAME=
USER_PASSWORD=

# 開発/本番切り替え（オプション）
# APP_ENV=production  # 本番（デフォルト）
# APP_ENV=development # 開発時：エラー表示・デバッグ有効

# デバッグ設定（オプション。APP_ENV=development でも有効化可）
# DEBUG_DISPLAY_ERRORS=true  # 画面上にエラー表示
# DEBUG_FLG=true             # デバッグモード
